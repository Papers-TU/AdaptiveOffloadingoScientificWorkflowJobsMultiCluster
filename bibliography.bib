	pages = {161--168},
	file = {IEEE Xplore Abstract Record:/Users/Leon/Zotero/storage/4GD7HN2C/6012708.html:text/html;PDF:/Users/Leon/Zotero/storage/I8DDWXB3/Wu und Datla - 2011 - On Performance Modeling and Prediction in Support of Scientific Workflow Optimization.pdf:application/pdf},
}

